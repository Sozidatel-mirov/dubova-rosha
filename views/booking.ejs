<%- include('partials/header') %>

<main>
    <div class="profile-container" style="max-width: 1200px; margin: 2rem auto; padding: 0 2rem;">
        <div class="profile-header" style="background: linear-gradient(135deg, var(--primary-green), var(--primary-dark)); margin-top: 150px;">
            <h1>Бронирование номера</h1>
            <p><%= room.name %></p>
            <a href="/rooms" class="btn btn-gold" style="margin-top: 1rem;">← Вернуться к списку номеров</a>
        </div>

        <% if (error) { %>
            <div class="error-message" style="background: #f8d7da; color: #721c24; padding: 1rem; border-radius: 10px; margin: 1rem 0; text-align: center;">
                ❌ <%= error %>
            </div>
        <% } %>

        <section class="booking-section" style="padding: 2rem 0;">
            <div class="booking-container" style="max-width: 900px; margin: 0 auto;">
                <div class="booking-block" style="background: var(--white); padding: 2rem; border-radius: 20px; box-shadow: var(--shadow);">
                    <!-- Информация о выбранном номере -->
                    <div class="room-info-summary" style="background: var(--bg-light); padding: 1.5rem; border-radius: 15px; margin-bottom: 2rem;">
                        <h3 style="color: var(--primary-green); margin-bottom: 1rem;">Выбранный номер</h3>
                        <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
                            <div style="flex: 1; min-width: 150px;">
                                <strong>Название:</strong> <%= room.name %><br>
                                <strong>Тип:</strong> 
                                <% if (room.type === 'standard') { %>Стандарт
                                <% } else if (room.type === 'improved') { %>Улучшенный
                                <% } else { %>Люкс<% } %><br>
                                <strong>Цена:</strong> <%= room.price %>₽ / сутки
                            </div>
                            <div style="flex: 1; min-width: 150px;">
                                <strong>Вместимость:</strong> до <%= room.capacity %> гостей<br>
                                <strong>Удобства:</strong> <%= room.amenities || 'Стандартный набор' %>
                            </div>
                        </div>
                    </div>
                    
                    <form id="bookingForm" action="/booking/create" method="POST">
                        <input type="hidden" name="roomId" value="<%= room.id %>" required>
                        
                        <div class="form-row" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1rem;">
                            <div class="form-group">
                                <label>Дата заезда</label>
                                <input type="text" name="checkIn" id="checkIn" class="datepicker" placeholder="Выберите дату" readonly required style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 10px; cursor: pointer; background: white;">
                            </div>
                            
                            <div class="form-group">
                                <label>Дата выезда</label>
                                <input type="text" name="checkOut" id="checkOut" class="datepicker" placeholder="Выберите дату" readonly required style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 10px; cursor: pointer; background: white;">
                            </div>
                        </div>
                        
                        <!-- Выбор дополнительных услуг (остаётся без изменений) -->
                        <div class="services-selection" style="margin: 1.5rem 0;">
                            <h3 style="margin-bottom: 1rem;">Дополнительные услуги</h3>
                            
                            <h4 style="margin: 1rem 0 0.5rem; color: #4a90e2;">Медицинские услуги (однократно)</h4>
                            <div id="medical-services" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 0.8rem; margin-bottom: 1rem;">
                                <% if (medicalServices && medicalServices.length) { %>
                                    <% medicalServices.forEach(service => { %>
                                        <label class="service-checkbox" style="display: flex; align-items: center; gap: 0.8rem; padding: 0.8rem; background: var(--bg-light); border-radius: 10px; cursor: pointer;">
                                            <input type="checkbox" name="services" value="<%= service.id %>" data-price="<%= service.price %>" data-name="<%= service.name %>" data-billing-type="<%= service.billingType %>" class="service-item">
                                            <div style="flex: 1;">
                                                <strong><%= service.name %></strong>
                                                <div style="font-size: 0.85rem; color: #666;"><%= service.duration || '30 мин' %></div>
                                            </div>
                                            <div style="color: var(--primary-green); font-weight: bold;"><%= service.price %>₽</div>
                                        </label>
                                    <% }) %>
                                <% } else { %>
                                    <p>Нет медицинских услуг</p>
                                <% } %>
                            </div>
                            
                            <h4 style="margin: 1rem 0 0.5rem; color: #2c6e49;">Оздоровительные услуги (ежедневно)</h4>
                            <div id="wellness-services" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 0.8rem; margin-bottom: 1rem;">
                                <% if (wellnessServices && wellnessServices.length) { %>
                                    <% wellnessServices.forEach(service => { %>
                                        <label class="service-checkbox" style="display: flex; align-items: center; gap: 0.8rem; padding: 0.8rem; background: var(--bg-light); border-radius: 10px; cursor: pointer;">
                                            <input type="checkbox" name="services" value="<%= service.id %>" data-price="<%= service.price %>" data-name="<%= service.name %>" data-billing-type="<%= service.billingType %>" class="service-item">
                                            <div style="flex: 1;">
                                                <strong><%= service.name %></strong>
                                                <div style="font-size: 0.85rem; color: #666;"><%= service.duration || '30 мин' %></div>
                                            </div>
                                            <div style="color: var(--primary-green); font-weight: bold;"><%= service.price %>₽</div>
                                        </label>
                                    <% }) %>
                                <% } else { %>
                                    <p>Нет оздоровительных услуг</p>
                                <% } %>
                            </div>
                            
                            <h4 style="margin: 1rem 0 0.5rem; color: #9673a6;">SPA услуги (ежедневно)</h4>
                            <div id="spa-services" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 0.8rem; margin-bottom: 1rem;">
                                <% if (spaServices && spaServices.length) { %>
                                    <% spaServices.forEach(service => { %>
                                        <label class="service-checkbox" style="display: flex; align-items: center; gap: 0.8rem; padding: 0.8rem; background: var(--bg-light); border-radius: 10px; cursor: pointer;">
                                            <input type="checkbox" name="services" value="<%= service.id %>" data-price="<%= service.price %>" data-name="<%= service.name %>" data-billing-type="<%= service.billingType %>" class="service-item">
                                            <div style="flex: 1;">
                                                <strong><%= service.name %></strong>
                                                <div style="font-size: 0.85rem; color: #666;"><%= service.duration || '30 мин' %></div>
                                            </div>
                                            <div style="color: var(--primary-green); font-weight: bold;"><%= service.price %>₽</div>
                                        </label>
                                    <% }) %>
                                <% } else { %>
                                    <p>Нет SPA услуг</p>
                                <% } %>
                            </div>
                        </div>
                       
                        <div class="form-group" style="margin-bottom: 20px;">
                            <label>Дополнительные пожелания</label>
                            <textarea name="notes" rows="3" placeholder="Укажите особые пожелания" style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 10px;"></textarea>
                        </div>
                         <div id="doctor-info" style="background: var(--bg-light); padding: 1rem; border-radius: 10px; margin: 1rem 0; display: none;">
                            <strong>Врач:</strong> <span id="doctor-name"></span>
                            <div id="doctor-details" style="font-size: 0.85rem; color: #666; margin-top: 0.25rem;"></div>
                        </div>
                        <div id="price-preview" style="background: #f0f0f0; padding: 1rem; border-radius: 10px; margin: 1rem 0;">
                            <div style="display: flex; justify-content: space-between; margin-bottom: 0.5rem;">
                                <span>Проживание:</span>
                                <span id="room-price-display"><%= room.price %>₽ × <span id="nights-count">0</span> ночей = <span id="room-total">0</span>₽</span>
                            </div>
                            <div id="services-price-list" style="border-top: 1px solid #ddd; padding-top: 0.5rem; margin-top: 0.5rem;"></div>
                            <div style="border-top: 2px solid var(--primary-green); padding-top: 0.8rem; margin-top: 0.8rem; display: flex; justify-content: space-between; font-weight: bold; font-size: 1.1rem;">
                                <span>Итого:</span>
                                <span id="total-price" style="color: var(--primary-green);">0₽</span>
                            </div>
                        </div>
                        
                        <% if (!user) { %>
                            <div class="alert" style="background: #fff3cd; color: #856404; padding: 1rem; border-radius: 10px; margin: 1rem 0;">
                                Для бронирования необходимо <a href="/login" style="color: #856404; font-weight: bold;">войти</a> или 
                                <a href="/register" style="color: #856404; font-weight: bold;">зарегистрироваться</a>
                            </div>
                        <% } %>
                        
                        <div class="form-actions" style="display: flex; gap: 1rem; margin-top: 1.5rem;">
                            <a href="/rooms" class="btn btn-outline" style="flex: 1; text-align: center;">Назад к номерам</a>
                            <button type="submit" class="btn btn-primary" id="submitBooking" style="flex: 2;" <%= !user ? 'disabled' : '' %>>
                                Подтвердить бронирование
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </section>
    </div>
</main>

<script>
    const roomId = <%= room.id %>;
    const roomPrice = <%= room.price %>;
    let roomTotal = 0;
    let selectedServices = [];
    let nights = 0;
    let flatpickrInstance1 = null;
    let flatpickrInstance2 = null;

    function calculateTotalPrice() {
        const checkIn = document.getElementById('checkIn').value;
        const checkOut = document.getElementById('checkOut').value;
        
        if (checkIn && checkOut) {
            const startDate = new Date(checkIn);
            const endDate = new Date(checkOut);
            
            if (endDate > startDate) {
                nights = Math.ceil((endDate - startDate) / (1000 * 60 * 60 * 24));
                roomTotal = roomPrice * nights;
                
                document.getElementById('nights-count').textContent = nights;
                document.getElementById('room-total').textContent = roomTotal;
                document.getElementById('room-price-display').innerHTML = `${roomPrice}₽ × ${nights} ночей = ${roomTotal}₽`;
                
                updateServicesPrice();
                return;
            }
        }
        
        nights = 0;
        roomTotal = 0;
        document.getElementById('nights-count').textContent = 0;
        document.getElementById('room-total').textContent = 0;
        updateServicesPrice();
    }

    const doctorsData = {};
<% if (medicalServices && medicalServices.length) { %>
    <% medicalServices.forEach(service => { %>
        <% if (service.doctorId) { %>
            doctorsData[<%= service.id %>] = {
                doctorId: <%= service.doctorId %>,
                doctorName: "<%= service.Doctor ? service.Doctor.name : 'Врач' %>",
                doctorPosition: "<%= service.Doctor ? service.Doctor.position : '' %>",
                doctorQualification: "<%= service.Doctor ? service.Doctor.qualification : '' %>"
            };
        <% } %>
    <% }) %>
<% } %>

// Функция обновления информации о враче
function updateDoctorInfo() {
    const doctorInfoDiv = document.getElementById('doctor-info');
    const doctorNameSpan = document.getElementById('doctor-name');
    const doctorDetailsSpan = document.getElementById('doctor-details');
    
    // Ищем выбранную медицинскую услугу с врачом
    let selectedMedicalService = null;
    for (const service of selectedServices) {
        if (service.category === 'medical' && doctorsData[service.id]) {
            selectedMedicalService = service;
            break;
        }
    }
    
    if (selectedMedicalService && doctorsData[selectedMedicalService.id]) {
        const doctor = doctorsData[selectedMedicalService.id];
        doctorNameSpan.textContent = doctor.doctorName;
        doctorDetailsSpan.innerHTML = `${doctor.doctorPosition} | ${doctor.doctorQualification}`;
        doctorInfoDiv.style.display = 'block';
    } else {
        doctorInfoDiv.style.display = 'none';
    }
}
    
    function updateServicesPrice() {
        const servicesPriceList = document.getElementById('services-price-list');
        let servicesTotal = 0;
        let servicesHtml = '';
        
        selectedServices.forEach(service => {
            let serviceTotal;
            let billingText;
            
            if (service.billingType === 'once') {
                serviceTotal = service.price;
                billingText = `${service.price}₽ (однократно)`;
            } else {
                serviceTotal = service.price * nights;
                billingText = `${service.price}₽ × ${nights} ночей = ${serviceTotal}₽`;
            }
            
            servicesTotal += serviceTotal;
            servicesHtml += `
                <div style="display: flex; justify-content: space-between; font-size: 0.9rem;">
                    <span>${service.name}</span>
                    <span>${billingText}</span>
                </div>
            `;
        });
        
        if (selectedServices.length > 0) {
            servicesPriceList.innerHTML = servicesHtml;
        } else {
            servicesPriceList.innerHTML = '<div style="color: #666; text-align: center;">Дополнительные услуги не выбраны</div>';
        }
        
        const total = roomTotal + servicesTotal;
        document.getElementById('total-price').textContent = total + '₽';
         updateDoctorInfo(); 
    }
    
    document.querySelectorAll('.service-item').forEach(checkbox => {
        checkbox.addEventListener('change', function() {
            const serviceId = parseInt(this.value);
            const serviceName = this.dataset.name;
            const servicePrice = parseInt(this.dataset.price);
            const billingType = this.dataset.billingType;
            
            if (this.checked) {
                selectedServices.push({
                    id: serviceId,
                    name: serviceName,
                    price: servicePrice,
                    billingType: billingType
                });
            } else {
                selectedServices = selectedServices.filter(s => s.id !== serviceId);
            }
            
            updateServicesPrice();
        });
    });
    
    // Инициализация календарей с подсветкой занятых дат
    async function initDatepickers() {
        // Загружаем занятые даты
        let disabledDates = [];
        try {
            const response = await fetch('/booking/api/booked-dates', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ roomId: roomId })
            });
            const data = await response.json();
            disabledDates = data.bookedDates || [];
            console.log('Loaded disabled dates:', disabledDates);
        } catch (error) {
            console.error('Error loading disabled dates:', error);
        }
        
        const today = new Date();
        today.setHours(0, 0, 0, 0);
        
        // Функция для проверки, занята ли дата
        const isDateDisabled = (date) => {
            const dateStr = date.toISOString().split('T')[0];
            return disabledDates.includes(dateStr);
        };
        
        flatpickrInstance1 = flatpickr("#checkIn", {
            locale: "ru",
            dateFormat: "Y-m-d",
            minDate: today,
            disable: disabledDates,
            onChange: function(selectedDates, dateStr, instance) {
                if (dateStr) {
                    flatpickrInstance2.set('minDate', dateStr);
                    calculateTotalPrice();
                }
            }
        });
        
        flatpickrInstance2 = flatpickr("#checkOut", {
            locale: "ru",
            dateFormat: "Y-m-d",
            minDate: today,
            disable: disabledDates,
            onChange: function(selectedDates, dateStr, instance) {
                if (dateStr && document.getElementById('checkIn').value) {
                    calculateTotalPrice();
                }
            }
        });
        
        // Добавляем кастомный стиль для занятых дат
        const style = document.createElement('style');
        style.textContent = `
            .flatpickr-day.disabled {
                background: #f8d7da !important;
                color: #721c24 !important;
                text-decoration: line-through;
                opacity: 0.7;
            }
            .flatpickr-day.disabled:hover {
                background: #f5c6cb !important;
            }
        `;
        document.head.appendChild(style);
    }
    
    document.getElementById('bookingForm').addEventListener('submit', function(e) {
        const servicesInput = document.createElement('input');
        servicesInput.type = 'hidden';
        servicesInput.name = 'selectedServices';
        servicesInput.value = JSON.stringify(selectedServices);
        this.appendChild(servicesInput);
        
        if (!document.getElementById('checkIn').value || !document.getElementById('checkOut').value) {
            e.preventDefault();
            alert('Пожалуйста, укажите даты заезда и выезда');
            return false;
        }
        
        return true;
    });
    
    // Запускаем инициализацию
    initDatepickers();
</script>

<style>
    .booking-section {
        scroll-margin-top: 80px;
    }
    
    .room-info-summary {
        border-left: 4px solid var(--primary-green);
    }
    
    .form-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1.5rem;
    }
    
    .service-checkbox {
        transition: all 0.3s ease;
    }
    
    .service-checkbox:hover {
        background: #e8f5e9 !important;
        transform: translateX(5px);
    }
    
    .error-message {
        animation: fadeIn 0.3s ease;
    }
    
    @keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    
    @media (max-width: 768px) {
        .form-actions {
            flex-direction: column;
        }
        .form-row {
            grid-template-columns: 1fr !important;
        }
    }
</style>

<%- include('partials/footer') %>