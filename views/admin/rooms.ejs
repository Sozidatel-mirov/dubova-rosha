<style>
    .admin-form input, .admin-form select, .admin-form textarea {
        transition: all 0.3s ease;
    }
    
    .admin-form input:focus, .admin-form select:focus, .admin-form textarea:focus {
        outline: none;
        border-color: var(--primary-green);
        box-shadow: 0 0 0 3px rgba(44, 110, 73, 0.1);
    }
    
    .rooms-table {
        overflow-x: auto;
    }
    
    .rooms-table table {
        border-collapse: collapse;
        width: 100%;
        min-width: 900px;
    }
    
    /* Фиксированная ширина колонок */
    .rooms-table th:first-child,
    .rooms-table td:first-child {
        width: 50px;
    }
    
    .rooms-table th:nth-child(2),
    .rooms-table td:nth-child(2) {
        width: 130px;
    }
    
    .rooms-table th:nth-child(3),
    .rooms-table td:nth-child(3) {
        width: 200px;
    }
    
    .rooms-table th:nth-child(4),
    .rooms-table td:nth-child(4) {
        width: 100px;
    }
    
    .rooms-table th:nth-child(5),
    .rooms-table td:nth-child(5) {
        width: 100px;
    }
    
    .rooms-table th:nth-child(6),
    .rooms-table td:nth-child(6) {
        width: 80px;
    }
    
    .rooms-table th:nth-child(7),
    .rooms-table td:nth-child(7) {
        width: 100px;
    }
    
    .rooms-table th:nth-child(8),
    .rooms-table td:nth-child(8) {
        width: 160px;
    }
    
    .rooms-table thead th {
        background: #2c6e49;
        color: white;
        padding: 12px;
        text-align: left;
    }
    
    .rooms-table td {
        padding: 12px;
        border-bottom: 1px solid #eee;
        vertical-align: middle;
    }
    
    .rooms-table tr:hover {
        background: #f9f9f9;
    }
    
    /* Стили для инпутов */
    .rooms-table input, .rooms-table select {
        padding: 6px 8px;
        border: 1px solid #ddd;
        border-radius: 5px;
        font-size: 0.85rem;
        width: 100%;
        box-sizing: border-box;
    }
    
    .rooms-table button {
        padding: 5px 10px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        font-size: 0.8rem;
    }
    
    .rooms-table img {
        width: 50px;
        height: 50px;
        object-fit: cover;
        border-radius: 8px;
    }
</style>

<%- include('../partials/footer') %>