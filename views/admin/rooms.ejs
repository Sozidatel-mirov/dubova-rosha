<%- include('../partials/header') %>

<main>
    <div class="profile-container" style="max-width: 1200px; margin: 2rem auto; padding: 0 2rem;">
        <div class="profile-header" style="background: linear-gradient(135deg, #2c6e49, #1e4a32);">
            <h2>Управление номерами</h2>
            <p>Добавление, редактирование и удаление номеров</p>
            <a href="/rooms" class="btn btn-gold" style="margin-top: 1rem;">Вернуться к списку номеров</a>
        </div>

        <div class="admin-form" style="background: var(--white); padding: 1.5rem; border-radius: 20px; margin-bottom: 2rem; box-shadow: var(--shadow);">
            <h3>Добавить новый номер</h3>
            <form action="/admin/rooms/add" method="POST" enctype="multipart/form-data" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem;">
                <div class="form-group">
                    <label>Название номера *</label>
                    <input type="text" name="name" required style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 10px;">
                </div>
                <div class="form-group">
                    <label>Тип номера</label>
                    <select name="type" style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 10px;">
                        <option value="standard">Стандарт</option>
                        <option value="improved">Улучшенный</option>
                        <option value="luxury">Люкс</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Цена за сутки (₽) *</label>
                    <input type="number" name="price" step="100" required style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 10px;">
                </div>
                <div class="form-group">
                    <label>Вместимость (гостей)</label>
                    <input type="number" name="capacity" value="2" style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 10px;">
                </div>
                <div class="form-group">
                    <label>Порядок отображения</label>
                    <input type="number" name="order" value="0" style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 10px;">
                </div>
                <div class="form-group">
                    <label>Доступен для бронирования</label>
                    <select name="isAvailable" style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 10px;">
                        <option value="true">Да</option>
                        <option value="false">Нет</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Изображение</label>
                    <input type="file" name="image" accept="image/*" style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 10px;">
                </div>
                <div class="form-group" style="grid-column: span 2;">
                    <label>Описание</label>
                    <textarea name="description" rows="2" style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 10px;"></textarea>
                </div>
                <div class="form-group" style="grid-column: span 2;">
                    <label>Удобства и оснащение</label>
                    <textarea name="amenities" rows="2" placeholder="Например: кондиционер, телевизор, холодильник, фен..." style="width: 100%; padding: 0.8rem; border: 1px solid #ddd; border-radius: 10px;"></textarea>
                </div>
                <div>
                    <button type="submit" class="btn btn-primary" style="width: 100%;">Добавить номер</button>
                </div>
            </form>
        </div>

        <h3>Стандартные номера</h3>
        <div class="rooms-table" style="overflow-x: auto; margin-bottom: 2rem;">
            <table style="width: 100%; border-collapse: collapse; background: var(--white); border-radius: 20px; overflow: hidden; box-shadow: var(--shadow);">
                <thead style="background: #2c6e49; color: white;">
                    <tr>
                        <th style="padding: 12px;">ID</th>
                        <th style="padding: 12px;">Изображение</th>
                        <th style="padding: 12px;">Название</th>
                        <th style="padding: 12px;">Цена</th>
                        <th style="padding: 12px;">Вместимость</th>
                        <th style="padding: 12px;">Порядок</th>
                        <th style="padding: 12px;">Доступен</th>
                        <th style="padding: 12px;">Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (standardRooms && standardRooms.length) { %>
                        <% standardRooms.forEach(room => { %>
                            <tr style="border-bottom: 1px solid #eee;">
                                <form action="/admin/rooms/edit/<%= room.id %>" method="POST" enctype="multipart/form-data" style="display: contents;">
                                    <td style="padding: 12px;"><%= room.id %></td>
                                    <td style="padding: 12px;">
                                        <% if (room.image) { %>
                                            <img src="<%= room.image %>" alt="<%= room.name %>" style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px;">
                                        <% } else { %>
                                            <span style="color: #999;">Нет фото</span>
                                        <% } %>
                                        <input type="file" name="image" accept="image/*" style="margin-top: 5px; font-size: 0.75rem;">
                                    </td>
                                    <td style="padding: 12px;">
                                        <input type="text" name="name" value="<%= room.name %>" style="width: 150px; padding: 6px; border: 1px solid #ddd; border-radius: 5px;">
                                        <input type="hidden" name="type" value="<%= room.type %>">
                                        <textarea name="description" style="display: none;"><%= room.description || '' %></textarea>
                                        <textarea name="amenities" style="display: none;"><%= room.amenities || '' %></textarea>
                                    </td>
                                    <td style="padding: 12px;">
                                        <input type="number" name="price" value="<%= room.price %>" step="100" style="width: 80px; padding: 6px; border: 1px solid #ddd; border-radius: 5px;">
                                    </td>
                                    <td style="padding: 12px;">
                                        <input type="number" name="capacity" value="<%= room.capacity %>" style="width: 60px; padding: 6px; border: 1px solid #ddd; border-radius: 5px;">
                                    </td>
                                    <td style="padding: 12px;">
                                        <input type="number" name="order" value="<%= room.order || 0 %>" style="width: 60px; padding: 6px; border: 1px solid #ddd; border-radius: 5px;">
                                    </td>
                                    <td style="padding: 12px;">
                                        <select name="isAvailable" style="padding: 6px; border: 1px solid #ddd; border-radius: 5px;">
                                            <option value="true" <%= room.isAvailable ? 'selected' : '' %>>Да</option>
                                            <option value="false" <%= !room.isAvailable ? 'selected' : '' %>>Нет</option>
                                        </select>
                                    </td>
                                    <td style="padding: 12px;">
                                        <button type="submit" style="background: #28a745; color: white; border: none; padding: 5px 10px; border-radius: 5px; cursor: pointer;">Сохранить</button>
                                     <form action="/admin/rooms/delete/<%= room.id %>" method="POST">
                                        <button type="submit" onclick="return confirm('Удалить номер \'<%= room.name %>\'?')" style="background: #28a745; color: white; border: none; padding: 5px 10px; border-radius: 5px; cursor: pointer;">Удалить</button>
                                    </form>
                                    </td>
                                </form>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr><td colspan="8" style="padding: 20px; text-align: center;">Нет стандартных номеров</td></tr>
                    <% } %>
                </tbody>
            </table>
        </div>

