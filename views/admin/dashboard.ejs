<%- include('../partials/header') %>

<main>
    <div class="profile-container" style="max-width: 1200px; margin: 2rem auto; padding: 0 2rem;">
        <div class="profile-header" style="background: linear-gradient(135deg, #2c6e49, #1e4a32);">
            <h2>Админ-панель</h2>
            <p>Управление контентом сайта санатория «Здоровье»</p>
        </div>

        <!-- Статистика -->
        <div class="stats-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
            <div class="stat-card" style="background: var(--white); padding: 1rem; border-radius: 15px; text-align: center; box-shadow: var(--shadow);">
                <div style="font-size: 2rem;"></div>
                <div style="font-size: 1.8rem; font-weight: bold; color: var(--primary-green);"><%= stats.users %></div>
                <div>Пользователей</div>
            </div>
            <div class="stat-card" style="background: var(--white); padding: 1rem; border-radius: 15px; text-align: center; box-shadow: var(--shadow);">
                <div style="font-size: 2rem;"></div>
                <div style="font-size: 1.8rem; font-weight: bold; color: var(--primary-green);"><%= stats.rooms %></div>
                <div>Номеров</div>
            </div>
            <div class="stat-card" style="background: var(--white); padding: 1rem; border-radius: 15px; text-align: center; box-shadow: var(--shadow);">
                <div style="font-size: 2rem;"></div>
                <div style="font-size: 1.8rem; font-weight: bold; color: var(--primary-green);"><%= stats.services %></div>
                <div>Услуг</div>
            </div>
            <div class="stat-card" style="background: var(--white); padding: 1rem; border-radius: 15px; text-align: center; box-shadow: var(--shadow);">
                <div style="font-size: 2rem;"></div>
                <div style="font-size: 1.8rem; font-weight: bold; color: var(--primary-green);"><%= stats.doctors %></div>
                <div>Врачей</div>
            </div>
            <div class="stat-card" style="background: var(--white); padding: 1rem; border-radius: 15px; text-align: center; box-shadow: var(--shadow);">
                <div style="font-size: 2rem;"></div>
                <div style="font-size: 1.8rem; font-weight: bold; color: var(--primary-green);"><%= stats.bookings %></div>
                <div>Бронирований</div>
            </div>
            <div class="stat-card" style="background: var(--white); padding: 1rem; border-radius: 15px; text-align: center; box-shadow: var(--shadow);">
                <div style="font-size: 2rem;"></div>
                <div style="font-size: 1.8rem; font-weight: bold; color: var(--primary-green);"><%= stats.gallery %></div>
                <div>Изображений</div>
            </div>
        </div>

        <!-- Статистика по бронированиям -->
        <div class="booking-stats" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
            <div class="stat-card" style="background: #2c6e49; padding: 1rem; border-radius: 15px; text-align: center; box-shadow: var(--shadow);">
                <div style="font-size: 1.5rem;"></div>
                <div style="font-size: 1.5rem; font-weight: bold; color: #fff;"><%= stats.pending %></div>
                <div style="font-size: 1rem; font-weight: bold; color: #fff;">Ожидают подтверждения</div>
            </div>
            <div class="stat-card" style="background: #2c6e49; padding: 1rem; border-radius: 15px; text-align: center; box-shadow: var(--shadow);">
                <div style="font-size: 1.5rem;"></div>
                <div style="font-size: 1.5rem; font-weight: bold; color: #fff;"><%= stats.confirmed %></div>
                <div style="font-size: 1rem; font-weight: bold; color: #fff;">Подтверждены</div>
            </div>
            <div class="stat-card" style="background: #2c6e49; padding: 1rem; border-radius: 15px; text-align: center; box-shadow: var(--shadow);">
                <div style="font-size: 1.5rem;"></div>
                <div style="font-size: 1.5rem; font-weight: bold; color: #fff;"><%= stats.cancelled %></div>
                <div style="font-size: 1rem; font-weight: bold; color: #fff;">Отменены</div>
            </div>
        </div>

        <!-- Финансовая статистика -->
        <div class="financial-stats" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
            <div class="stat-card" style="background: linear-gradient(135deg, #2c6e49, #1e4a32); color: white; padding: 1rem; border-radius: 15px; text-align: center; box-shadow: var(--shadow);">
                <div style="font-size: 1.5rem;"></div>
                <div style="font-size: 1.5rem; font-weight: bold;"><%= stats.totalRevenue.toLocaleString() %> ₽</div>
                <div>Общая выручка</div>
            </div>
            <div class="stat-card" style="background: linear-gradient(135deg, #2c6e49, #1e4a32); color: white; padding: 1rem; border-radius: 15px; text-align: center; box-shadow: var(--shadow);">
                <div style="font-size: 1.5rem;"></div>
                <div style="font-size: 1.5rem; font-weight: bold;"><%= stats.avgPrice.toLocaleString() %> ₽</div>
                <div>Средняя стоимость бронирования</div>
            </div>
        </div>

        <!-- Бронирования по месяцам -->
        <h3 style="margin-bottom: 1rem;">Бронирования по месяцам (текущий год)</h3>
        <div class="chart-container" style="background: var(--white); padding: 1rem; border-radius: 20px; box-shadow: var(--shadow); margin-bottom: 2rem;">
            <canvas id="bookingsChart" style="max-height: 300px; width: 100%;"></canvas>
        </div>

        <!-- Топ услуг -->
        <h3 style="margin-bottom: 1rem;">Популярные услуги</h3>
        <div class="top-services" style="background: var(--white); border-radius: 20px; box-shadow: var(--shadow); margin-bottom: 2rem; overflow: hidden;">
            <table style="width: 100%; border-collapse: collapse;">
                <thead style="background: #2c6e49; color: white;">
                    <tr>
                        <th style="padding: 12px;">Услуга</th>
                        <th style="padding: 12px;">Количество заказов</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (topServices && topServices.length) { %>
                        <% topServices.forEach(service => { %>
                            <tr style="border-bottom: 1px solid #eee;">
                                <td style="padding: 12px;"><%= service[0] %></td>
                                <td style="padding: 12px; padding-left: 26rem;"><%= service[1] %></td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="2" style="padding: 20px; text-align: center;">Нет данных</td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>

        <!-- Кнопки управления -->
        <h3 style="margin-bottom: 1rem;">Управление разделами</h3>
        <div class="admin-buttons-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem;">
            <a href="/admin/rooms" class="admin-btn" style="background: #2c6e49; color: white; padding: 1rem; border-radius: 10px; text-decoration: none; text-align: center;">Номера</a>
            <a href="/admin/services" class="admin-btn" style="background: #2c6e49; color: white; padding: 1rem; border-radius: 10px; text-decoration: none; text-align: center;">Услуги</a>
            <a href="/admin/doctors" class="admin-btn" style="background: #2c6e49; color: white; padding: 1rem; border-radius: 10px; text-decoration: none; text-align: center;">Врачи</a>
            <a href="/admin/gallery" class="admin-btn" style="background: #2c6e49; color: white; padding: 1rem; border-radius: 10px; text-decoration: none; text-align: center;">Галерея</a>
            <a href="/admin/bookings" class="admin-btn" style="background: #2c6e49; color: white; padding: 1rem; border-radius: 10px; text-decoration: none; text-align: center;">Бронирования</a>
        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
    // График бронирований по месяцам
    const ctx = document.getElementById('bookingsChart').getContext('2d');
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: ['Янв', 'Фев', 'Мар', 'Апр', 'Май', 'Июн', 'Июл', 'Авг', 'Сен', 'Окт', 'Ноя', 'Дек'],
            datasets: [{
                label: 'Количество бронирований',
                data: <%= JSON.stringify(monthlyBookings) %>,
                backgroundColor: '#2c6e49',
                borderColor: '#1e4a32',
                borderWidth: 1
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: true,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { stepSize: 1 }
                }
            }
        }
    });
</script>

<style>
    .admin-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
    }
    
    .stat-card {
        transition: transform 0.3s ease;
    }
    
    .stat-card:hover {
        transform: translateY(-3px);
    }
</style>

<%- include('../partials/footer') %>