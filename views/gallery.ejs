<%- include('partials/header') %>

<main>
    <div class="profile-container" style="max-width: 1200px; margin: 2rem auto; padding: 0 2rem;">
        <div class="profile-header" style="background: linear-gradient(135deg, var(--primary-green), var(--primary-dark)); margin-top: 150px;">
            <h1>Галерея</h1>
            <p>Фотографии территории, номеров и процедур</p>
            <% if (user && user.role === 'admin') { %>
                <a href="/admin/gallery" class="btn btn-gold" style="margin-top: 1rem;">Редактировать галерею</a>
            <% } %>
        </div>

        <section class="gallery" style="padding: 2rem 0; color: (255, 0, 0, 0);">
            <div class="gallery-filters">
                <button class="filter-btn active" data-category="all">Все фото</button>
                <button class="filter-btn" data-category="territory">Территория</button>
                <button class="filter-btn" data-category="rooms">Номера</button>
                <button class="filter-btn" data-category="procedures">Процедуры</button>
                <button class="filter-btn" data-category="nature">Природа</button>
            </div>
            <div class="gallery-container" class="gallery" style="background-color: rgba(255, 0, 0, 0);">
                <% if (images && images.length) { %>
                    <% images.forEach(image => { %>
                        <div class="gallery-item" data-category="<%= image.category %>">
                            <img src="<%= image.filename %>" alt="<%= image.title %>">
                        </div>
                    <% }) %>
                <% } else { %>
                    <p style="grid-column: span 4; text-align: center;">Нет изображений в галерее</p>
                <% } %>
            </div>
        </section>
    </div>
</main>

<script>
    // Фильтрация галереи
    const filterButtons = document.querySelectorAll('.filter-btn');
    const galleryItems = document.querySelectorAll('.gallery-item');
    
    filterButtons.forEach(btn => {
        btn.addEventListener('click', () => {
            const category = btn.dataset.category;
            
            filterButtons.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            
            galleryItems.forEach(item => {
                if (category === 'all' || item.dataset.category === category) {
                    item.style.display = 'block';
                } else {
                    item.style.display = 'none';
                }
            });
        });
    });
</script>

<style>
    .gallery-filters {
        text-align: center;
        margin-bottom: 2rem;
    }
    
    .filter-btn {
        padding: 0.5rem 1.5rem;
        margin: 0 0.5rem;
        background: var(--bg-light);
        border: none;
        border-radius: 25px;
        cursor: pointer;
        transition: var(--transition);
    }
    
    .filter-btn.active,
    .filter-btn:hover {
        background: var(--primary-green);
        color: var(--white);
    }
    
    .gallery-container {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.5rem;
    }
    
    .gallery-item {
        position: relative;
        height: 250px;
        border-radius: 15px;
        overflow: hidden;
        cursor: pointer;
    }
    
    .gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: var(--transition);
    }
    
    .gallery-item:hover img {
        transform: scale(1.1);
    }
</style>

<%- include('partials/footer') %>