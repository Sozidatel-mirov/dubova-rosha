<%- include('partials/header') %>

<main>
    <div class="profile-container" style="max-width: 1200px; margin: 2rem auto; padding: 0 2rem;">
        <div class="profile-header" style="background: linear-gradient(135deg, var(--primary-green), var(--primary-dark)); margin-top: 150px;">
            <h1><%= room.name %></h1>
            <p>Детальная информация о номере</p>
            <a href="/rooms" class="btn btn-gold" style="margin-top: 1rem;">← Вернуться к списку номеров</a>
        </div>

        <section class="room-detail" style="padding: 2rem 0;">
            <div class="room-detail-container" style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem;">
                <!-- Изображение номера -->
                <div class="room-detail-image" style="background: var(--bg-light); border-radius: 20px; overflow: hidden; box-shadow: var(--shadow);">
                    <% if (room.image) { %>
                        <img src="<%= room.image %>" alt="<%= room.name %>" style="width: 100%; height: 100%; object-fit: cover;">
                    <% } else { %>
                        <div style="width: 100%; height: 400px; background: linear-gradient(135deg, #2c6e49, #1e4a32); display: flex; align-items: center; justify-content: center; color: white; font-size: 5rem;">🏨</div>
                    <% } %>
                </div>
                
                <!-- Информация о номере -->
                <div class="room-detail-info" style="background: var(--white); padding: 2rem; border-radius: 20px; box-shadow: var(--shadow);">
                    <h2 style="color: var(--primary-green); margin-bottom: 1rem;"><%= room.name %></h2>
                    
                    <div class="room-type" style="margin-bottom: 1rem;">
                        <span class="type-badge" style="background: var(--bg-light); padding: 0.3rem 1rem; border-radius: 20px; font-size: 0.85rem;">
                            <% if (room.type === 'standard') { %>Стандарт
                            <% } else if (room.type === 'improved') { %>Улучшенный
                            <% } else { %>Люкс<% } %>
                        </span>
                    </div>
                    
                    <div class="room-description" style="margin-bottom: 1.5rem;">
                        <h3>Описание</h3>
                        <p style="color: var(--text-light); line-height: 1.6;"><%= room.description %></p>
                    </div>
                    
                    <div class="room-capacity" style="margin-bottom: 1.5rem;">
                        <h3>Вместимость</h3>
                        <p style="color: var(--text-light);">До <%= room.capacity %> гостей</p>
                    </div>
                    
                    <div class="room-amenities" style="margin-bottom: 1.5rem;">
                        <h3>Удобства и оснащение</h3>
                        <p style="color: var(--text-light); line-height: 1.6;"><%= room.amenities || 'Стандартный набор удобств' %></p>
                    </div>
                    
                    <div class="room-price" style="margin-bottom: 2rem;">
                        <h3>Стоимость</h3>
                        <div class="price" style="font-size: 2rem; font-weight: bold; color: var(--primary-green);">
                            <%= room.price %>₽ <span style="font-size: 1rem; font-weight: normal;">/ сутки</span>
                        </div>
                    </div>
                    
                    <a href="/booking/<%= room.id %>" class="btn btn-primary" style="width: 100%; text-align: center; display: block; padding: 1rem;">
                        Забронировать этот номер
                    </a>
                </div>
            </div>
        </section>
    </div>
</main>

<style>
    @media (max-width: 768px) {
        .room-detail-container {
            grid-template-columns: 1fr !important;
        }
        
        .room-detail-image {
            height: 300px;
        }
        
        .room-detail-info {
            padding: 1.5rem;
        }
    }
</style>

<%- include('partials/footer') %>